<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AcademicApp"
        android:usesCleartextTraffic="true">

        <!-- LOGIN (Launcher) -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- PROFESOR -->
        <activity android:name=".ui.profesor.ProfesorHomeActivity" android:exported="false"/>
        <activity android:name=".ui.profesor.asistencia.MarcarAsistenciaActivity" android:exported="false"/>
        <activity android:name=".ui.profesor.asistencia.SeleccionarCursoAsistenciaActivity" android:exported="false"/>
        <activity android:name=".ui.profesor.notas.IngresarNotasActivity" android:exported="false"/>
        <activity android:name=".ui.profesor.notas.ModificarNotasActivity" android:exported="false"/>
        <activity android:name=".ui.profesor.notas.VerNotasProfesorActivity" android:exported="false"/>
        <activity android:name=".ui.profesor.notas.SeleccionarCursoNotaActivity" android:exported="false"/>
        <activity android:name=".ui.profesor.justificacion.GestionJustificacionActivity" android:exported="false"/>

    </application>
</manifest>
