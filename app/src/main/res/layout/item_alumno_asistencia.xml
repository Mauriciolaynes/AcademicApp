<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvAlumnoNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rodríguez, Luis"
            android:textColor="@color/colorTextPrimary"
            android:textSize="15sp"
            android:textStyle="normal" />

        <RadioGroup
            android:id="@+id/rgAsistencia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbPresente"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:button="@null"
                android:background="@drawable/selector_asistencia_p"
                android:gravity="center"
                android:text="P"
                android:textColor="@color/white" />

            <RadioButton
                android:id="@+id/rbTardanza"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:button="@null"
                android:background="@drawable/selector_asistencia_t"
                android:gravity="center"
                android:text="T"
                android:textColor="@color/white" />

            <RadioButton
                android:id="@+id/rbFalta"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:button="@null"
                android:background="@drawable/selector_asistencia_f"
                android:gravity="center"
                android:text="F"
                android:textColor="@color/white" />
        </RadioGroup>
    </LinearLayout>
</androidx.cardview.widget.CardView>