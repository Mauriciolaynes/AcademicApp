<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_inicio">

    <fragment
        android:id="@+id/nav_inicio"
        android:name="com.academicapp.ui.profesor.InicioFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_inicio" />

    <fragment
        android:id="@+id/nav_asistencia"
        android:name="com.academicapp.ui.profesor.ListaCursosFragment"
        android:label="Asistencia"
        tools:layout="@layout/fragment_lista_cursos">
        <argument
            android:name="tipo"
            android:defaultValue="asistencia"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/nav_notas"
        android:name="com.academicapp.ui.profesor.ListaCursosFragment"
        android:label="Notas"
        tools:layout="@layout/fragment_lista_cursos">
        <argument
            android:name="tipo"
            android:defaultValue="notas"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/nav_perfil"
        android:name="com.academicapp.ui.profesor.PerfilFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_perfil" />

</navigation>
